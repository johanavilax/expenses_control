# ─────────────────────────────────────────────────────────────
# PÚBLICAS (Next) — expuestas al navegador. Solo claves públicas.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-clave-anon-publica

# ─────────────────────────────────────────────────────────────
# SECRETAS (servidor) — usadas por los Route Handlers /api/*.
# En local van en .env; en producción se configuran en Vercel
# (Project → Settings → Environment Variables), NUNCA con NEXT_PUBLIC_.
# ─────────────────────────────────────────────────────────────
BASIQ_API_KEY=tu-api-key-de-basiq
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────────────────────
# SEED (npm run seed) — crea usuarios y siembra su presupuesto.
# ─────────────────────────────────────────────────────────────
# Clave service_role de Supabase (Settings → API). NUNCA va al frontend.
SUPABASE_SERVICE_ROLE_KEY=tu-clave-service-role
# Usuarios a crear: varios (JSON) ...
# SEED_USERS=[{"email":"tu@email.com","password":"unaClaveSegura"}]
# ... o uno solo:
SEED_USER_EMAIL=tu@email.com
SEED_USER_PASSWORD=unaClaveSegura
